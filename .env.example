# DOLI Network Configuration
#
# Place this file at ~/.doli/{network}/.env to override default network parameters.
# For example: ~/.doli/devnet/.env for devnet configuration.
#
# IMPORTANT: Security-critical parameters are LOCKED for mainnet.
# Attempting to override locked parameters will be ignored with a warning.
#
# Locked for mainnet (cannot be changed):
#   - DOLI_SLOT_DURATION
#   - DOLI_GENESIS_TIME
#   - DOLI_BOND_UNIT
#   - DOLI_INITIAL_REWARD
#   - DOLI_UNBONDING_PERIOD
#   - DOLI_VDF_ITERATIONS
#   - DOLI_HEARTBEAT_VDF_ITERATIONS
#   - DOLI_VDF_REGISTER_ITERATIONS
#   - DOLI_BLOCKS_PER_YEAR
#   - DOLI_BLOCKS_PER_REWARD_EPOCH
#   - DOLI_COINBASE_MATURITY
#   - DOLI_AUTOMATIC_GENESIS_BOND
#   - DOLI_GENESIS_BLOCKS

# === Networking ===
# These can be configured for all networks

# Default P2P port (mainnet: 30303, testnet: 40303, devnet: 50303)
# DOLI_P2P_PORT=50303

# Default RPC port (mainnet: 8545, testnet: 18545, devnet: 28545)
# DOLI_RPC_PORT=28545

# Default metrics port
# DOLI_METRICS_PORT=9090

# Bootstrap nodes (comma-separated multiaddr format)
# DOLI_BOOTSTRAP_NODES=/ip4/127.0.0.1/tcp/50303,/ip4/192.168.1.100/tcp/50303

# === Timing (devnet only) ===
# These are locked for mainnet/testnet to ensure consensus compatibility

# Slot duration in seconds (default: 10)
# DOLI_SLOT_DURATION=10

# Genesis timestamp (Unix timestamp, 0 = dynamic for devnet)
# DOLI_GENESIS_TIME=0

# Veto period for updates in seconds (mainnet: 7 days, devnet: 60s)
# DOLI_VETO_PERIOD_SECS=60

# Grace period after update approval in seconds (mainnet: 48h, devnet: 30s)
# DOLI_GRACE_PERIOD_SECS=30

# Unbonding period in blocks (mainnet: 60480 = 7 days, devnet: 60)
# DOLI_UNBONDING_PERIOD=60

# Inactivity threshold in blocks
# DOLI_INACTIVITY_THRESHOLD=30

# === Economics (devnet only) ===
# These are locked for mainnet to preserve emission schedule

# Bond unit size in base units (mainnet: 10B = 100 DOLI, devnet: 100M = 1 DOLI)
# DOLI_BOND_UNIT=100000000

# Initial block reward in base units (mainnet: 100M = 1 DOLI, devnet: 2B = 20 DOLI)
# DOLI_INITIAL_REWARD=2000000000

# Base registration fee in base units
# DOLI_REGISTRATION_BASE_FEE=1000

# Maximum registration fee cap
# DOLI_MAX_REGISTRATION_FEE=10000000

# Automatic genesis bond amount
# DOLI_AUTOMATIC_GENESIS_BOND=10000000000

# Genesis phase duration in blocks (0 for mainnet/testnet, 40 for devnet)
# DOLI_GENESIS_BLOCKS=40

# === VDF (devnet only) ===
# These are locked for mainnet to ensure consensus security

# VDF iterations for block production (mainnet: 100000, devnet: 1)
# DOLI_VDF_ITERATIONS=1

# Heartbeat VDF iterations (mainnet: 10000000)
# DOLI_HEARTBEAT_VDF_ITERATIONS=10000000

# VDF iterations for registration proof (mainnet: 600000000, devnet: 5000000)
# DOLI_VDF_REGISTER_ITERATIONS=5000000

# === Time Structure (devnet only) ===
# These are locked for mainnet to preserve emission schedule

# Blocks per simulated "year" (mainnet: 3153600, devnet: 144)
# DOLI_BLOCKS_PER_YEAR=144

# Blocks per reward epoch (mainnet: 360, devnet: 4)
# DOLI_BLOCKS_PER_REWARD_EPOCH=4

# Coinbase maturity in blocks (mainnet: 100, devnet: 10)
# DOLI_COINBASE_MATURITY=10

# Slots per reward epoch (legacy)
# DOLI_SLOTS_PER_REWARD_EPOCH=30

# Bootstrap blocks count
# DOLI_BOOTSTRAP_BLOCKS=60

# === Update System ===

# Minimum voting age in seconds
# DOLI_MIN_VOTING_AGE_SECS=60

# Update check interval in seconds
# DOLI_UPDATE_CHECK_INTERVAL_SECS=10

# Crash window for automatic rollback in seconds
# DOLI_CRASH_WINDOW_SECS=60

# Maximum registrations per block
# DOLI_MAX_REGISTRATIONS_PER_BLOCK=20
