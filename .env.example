# DOLI Devnet Configuration
#
# Copy this file to .env in repo root: cp .env.example .env
# Then run: cargo run -p doli-node -- devnet init
# All parameters are configurable for devnet (no locked params)

# === Networking ===
DOLI_P2P_PORT=50303
DOLI_RPC_PORT=28545
DOLI_METRICS_PORT=29090
# DOLI_BOOTSTRAP_NODES=

# === Timing ===
DOLI_SLOT_DURATION=3
DOLI_PRESENCE_WINDOW_MS=1000
DOLI_GENESIS_TIME=0
DOLI_VETO_PERIOD_SECS=60
DOLI_GRACE_PERIOD_SECS=30
DOLI_BOOTSTRAP_GRACE_PERIOD_SECS=5
DOLI_UNBONDING_PERIOD=60
DOLI_INACTIVITY_THRESHOLD=30

# === Economics ===
DOLI_BOND_UNIT=100000000
DOLI_INITIAL_REWARD=4000000000
DOLI_REGISTRATION_BASE_FEE=1000
DOLI_MAX_REGISTRATION_FEE=10000000
DOLI_AUTOMATIC_GENESIS_BOND=10000000000
DOLI_GENESIS_BLOCKS=40

# === VDF ===
DOLI_VDF_ITERATIONS=1
DOLI_HEARTBEAT_VDF_ITERATIONS=10000000
DOLI_VDF_REGISTER_ITERATIONS=5000000

# === Time Structure ===
DOLI_BLOCKS_PER_YEAR=144
DOLI_BLOCKS_PER_REWARD_EPOCH=4
DOLI_COINBASE_MATURITY=10
DOLI_SLOTS_PER_REWARD_EPOCH=30
DOLI_BOOTSTRAP_BLOCKS=60

# === Update System ===
DOLI_MIN_VOTING_AGE_SECS=60
DOLI_UPDATE_CHECK_INTERVAL_SECS=10
DOLI_CRASH_WINDOW_SECS=60
DOLI_MAX_REGISTRATIONS_PER_BLOCK=20

# === Fallback System ===
DOLI_FALLBACK_TIMEOUT_MS=2000
DOLI_MAX_FALLBACK_RANKS=5
DOLI_NETWORK_MARGIN_MS=200

# === Gossip Mesh ===
# Controls gossipsub mesh topology. Devnet defaults are larger (12/8/48)
# because --no-dht creates a star topology where pruned nodes have no
# alternative peers. Mainnet/testnet use standard values (6/4/12) with
# DHT providing peer rotation.
DOLI_MESH_N=15
DOLI_MESH_N_LOW=10
DOLI_MESH_N_HIGH=35
DOLI_GOSSIP_LAZY=15
