# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Cargo.lock — committed for reproducible binary builds
# (Rust best practice: commit for applications, ignore for libraries)
# Cargo.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
*.o
*.a
*.so
*.dylib

# Test outputs
*.log
*.tmp

# Local configuration
config.local.toml
.env
.env.local
.env.*
# Keep .env.example files as documentation
!.env.example
!.env.example.*

# Data directories
data/
.doli/

# Keys (never commit!)
*.key
*.pem
wallet.json
# Internal docs (not for public repo)
*.internal.md
proptest-regressions/

# Skill packages (generated zips)
*.skill

# Claude worktrees
.claude/worktrees/

