# DOLI Mainnet Configuration
#
# Place this file at ~/.doli/mainnet/.env
#
# WARNING: Security-critical parameters are LOCKED for mainnet.
# The following parameters will be IGNORED if set (hardcoded values enforced):
#   - DOLI_SLOT_DURATION (locked: 10)
#   - DOLI_GENESIS_TIME (locked: 1769904000)
#   - DOLI_BOND_UNIT (locked: 10000000000)
#   - DOLI_INITIAL_REWARD (locked: 100000000)
#   - DOLI_UNBONDING_PERIOD (locked: 60480)
#   - DOLI_VDF_ITERATIONS (locked: 100000)
#   - DOLI_HEARTBEAT_VDF_ITERATIONS (locked: 10000000)
#   - DOLI_VDF_REGISTER_ITERATIONS (locked: 600000000)
#   - DOLI_BLOCKS_PER_YEAR (locked: 3153600)
#   - DOLI_BLOCKS_PER_REWARD_EPOCH (locked: 360)
#   - DOLI_COINBASE_MATURITY (locked: 100)
#   - DOLI_AUTOMATIC_GENESIS_BOND (locked: 10000000000)
#   - DOLI_GENESIS_BLOCKS (locked: 0)

# === Networking (configurable) ===
DOLI_P2P_PORT=30303
DOLI_RPC_PORT=8545
DOLI_METRICS_PORT=9090
DOLI_BOOTSTRAP_NODES=/dns4/seed1.doli.network/tcp/30303,/dns4/seed2.doli.network/tcp/30303

# === Timing (configurable) ===
DOLI_VETO_PERIOD_SECS=604800
DOLI_GRACE_PERIOD_SECS=172800
DOLI_INACTIVITY_THRESHOLD=60480

# === Economics (configurable) ===
DOLI_REGISTRATION_BASE_FEE=100000
DOLI_MAX_REGISTRATION_FEE=1000000000

# === Time Structure (configurable) ===
DOLI_SLOTS_PER_REWARD_EPOCH=8640
DOLI_BOOTSTRAP_BLOCKS=60480

# === Update System (configurable) ===
DOLI_MIN_VOTING_AGE_SECS=2592000
DOLI_UPDATE_CHECK_INTERVAL_SECS=21600
DOLI_CRASH_WINDOW_SECS=3600
DOLI_MAX_REGISTRATIONS_PER_BLOCK=5
